{
  "$schema": "https://docs.umbraco.com/umbraco-package-schema",
  "name": "Testsite Translation App",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "workspaceView",
      "alias": "testsite.workspaceView.translate",
      "name": "Translate Node",
      "element": "/App_Plugins/TranslationAction/translate-app.js",
      "elementName": "testsite-translate-app",
      "weight": 1,
      "meta": {
        "label": "Translate",
        "pathname": "translate",
        "icon": "icon-globe"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.WorkspaceAlias",
          "match": "Umb.Workspace.Document"
        }
      ]
    }
  ]
}
